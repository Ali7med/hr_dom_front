# عنوان الـ API (انظر hr_dom_docs/ENVIRONMENTS.md).
# مهم (BE-SEC/ADR-0003): المصادقة عبر كوكيز HttpOnly + CSRF تتطلّب أن يكون الـ API
# نفس-أصل (same-origin) ليُقرأ كوكي XSRF. لذلك العنوان نسبي:
VITE_API_BASE_URL=/api/v1

# التطوير: Vite يوكّل /api إلى هذا الهدف (انظر vite.config.ts server.proxy).
VITE_DEV_API_TARGET=http://127.0.0.1:8000

# الإنتاج: اخدم الفرونت خلف نفس الأصل (nginx يوكّل /api → الباك) وأبقِ العنوان نسبياً،
# أو استخدم أصلاً صريحاً https على نفس الموقع (same-site) مع ضبط نطاق الكوكي في الباك.
